{
  "name": "jakeberv-site",
  "version": "1.0.0",
  "description": "JavaScript asset build for jakeberv.github.io",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/jakeberv/jakeberv.github.io.git"
  },
  "license": "MIT",
  "engines": {
    "node": "20.x",
    "npm": ">=10 <11"
  },
  "dependencies": {
    "jquery": "3.7.1"
  },
  "devDependencies": {
    "onchange": "7.1.0",
    "uglify-js": "3.19.3"
  },
  "scripts": {
    "build:js": "node scripts/build-js.mjs",
    "check:js": "node scripts/build-js.mjs --check",
    "watch:js": "onchange \"assets/js/_main.js\" \"assets/js/plugins/jquery.greedy-navigation.js\" -- npm run build:js",
    "test": "node --test scripts/qa/*.test.mjs && npm run check:js"
  }
}
