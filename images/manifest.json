---
layout: none
permalink: /images/manifest.json
---
{
  "name": {{ site.title | jsonify }},
  "short_name": {{ site.name | jsonify }},
  "description": {{ site.description | jsonify }},
  "start_url": {{ "/" | relative_url | jsonify }},
  "lang": {{ site.locale | default: "en" | jsonify }},
  "icons": [
    {
      "src": {{ "/images/android-chrome-192x192.png" | relative_url | jsonify }},
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": {{ "/images/android-chrome-512x512.png" | relative_url | jsonify }},
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
